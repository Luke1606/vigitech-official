{
  "name": "radar-api",
  "version": "1.0.0",
  "description": "Plataforma avanzada de vigilancia tecnológica diseñada para fusionar visión estratégica e inteligencia de datos. Este repositorio alberga el punto de entrada (Portal) y el motor de monitoreo en tiempo real a través de nuestro servicio de Radar.",
  "author": "Luis Alberto Hernández Roselló",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "dev:infra": "npm run db:up && sleep 10",
    "dev:full": "npm run db:up && npm run db:migrate:dev && npm run db:generate && npm run start:dev",
    "dev:reset": "npm run db:clean && npm run dev:full",
    "db:up": "docker-compose up -d radar-db pgadmin",
    "db:down": "docker-compose down",
    "db:restart": "docker-compose restart radar-db",
    "db:wait": "npx wait-port 4000",
    "db:clean": "docker-compose down -v --remove-orphans",
    "db:clean-resources": "docker system prune -f",
    "db:logs": "docker-compose logs -f radar-db",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed1": "ts-node-dev prisma/seed.ts 1",
    "db:seed2": "ts-node-dev prisma/seed.ts 2",
    "db:seed3": "ts-node-dev prisma/seed.ts 3",
    "db:studio": "prisma studio",
    "db:status": "prisma migrate status",
    "test": "jest --coverage --testPathIgnorePatterns=__e2e_tests__ .*\\.e2e-spec\\.ts$",
    "test:watch": "jest --watch --testPathIgnorePatterns=__e2e_tests__ .*\\.e2e-spec\\.ts$",
    "test:e2e": "cross-env NODE_ENV=test jest --coverage --config ./__e2e_tests__/jest-e2e.json --rootDir . --runInBand",
    "test:e2e:watch": "cross-env NODE_ENV=test jest --watch --coverage --config ./__e2e_tests__/jest-e2e.json --rootDir . --runInBand",
    "test:db:up": "docker-compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker-compose -f docker-compose.test.yml down",
    "test:e2e:run": "npm run test:db:up && npx wait-port 5433 && cross-env NODE_ENV=test npm run db:migrate:deploy && npm run db:generate && npm run test:e2e",
    "test:ci": "npm run test:cov && npm run test:e2e:run && npm run test:db:down",
    "docker:build": "docker build -t radar-api:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env radar-api:latest",
    "health:db": "npx wait-port localhost:4000 -t 30000",
    "health:api": "npx wait-port localhost:3000 -t 30000"
  },
  "dependencies": {
    "@clerk/backend": "^2.19.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.7",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.7",
    "@nestjs/platform-express": "^11.1.7",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "axios": "^1.7.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "cron-parser": "^5.4.0",
    "csv-parser": "^3.2.0",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/mapped-types": "^2.0.2",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/testing": "^11.1.7",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.12",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.6.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^15.8.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^7.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "coveragePathIgnorePatterns": [
      "main.ts",
      ".module.ts$",
      ".dto.ts$",
      ".type.ts$",
      ".enum.ts$",
      "modules/data-hub/collection/.*",
      "modules/data-hub/processing/.*",
      "modules/data-hub/orchestration/.*"
    ]
  }
}
